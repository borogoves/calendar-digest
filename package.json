{
  "name": "calendar-digest",
  "version": "0.1.0",
  "description": "Responsive summarization for calendar data — summarize a list of events into text sized for any space, from a watch face to a full display.",
  "type": "module",
  "author": "Dave Hunkins",
  "homepage": "https://claude.ai/code/artifact/64c7fb1a-abfe-4dac-9b5d-53fea590f3a7",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/borogoves/calendar-digest.git"
  },
  "bugs": {
    "url": "https://github.com/borogoves/calendar-digest/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "explore": "npm run build --silent && node examples/fixtures/run.mjs",
    "live": "npm run build --silent && node examples/live/harness.mjs",
    "prepare": "tsup",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "google-auth-library": "^10.9.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
